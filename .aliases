# ~/.aliases
# Shell aliases sourced by .bashrc

# Enable color support of ls and grep
if [ -x /usr/bin/dircolors ]; then
    test -r ~/.dircolors && eval "$(dircolors -b ~/.dircolors)" || eval "$(dircolors -b)"
    alias ls='ls --color=auto'
    alias grep='grep --color=auto'
    alias fgrep='fgrep --color=auto'
    alias egrep='egrep --color=auto'
fi

# ls aliases
alias ll='ls -alF'
alias la='ls -A'
alias l='ls -CF'

# Git aliases
alias gl='git log --oneline --graph --decorate'
alias glog='git log --oneline --graph --decorate --all'

# Zellij
alias zj='zellij'
alias zja='zellij attach'
alias zjl='zellij list-sessions'
alias zjk='zellij kill-session'
alias zjka='zellij kill-all-sessions'
# Open the current directory as a project: nvim (2/3) + Claude Code (1/3),
# in a zellij session named after the directory. Creates it with the project
# layout if missing, attaches if it already exists.
# Note: `zellij attach -c` does create-or-attach in one step; the `--session`
# flag does NOT create a new session (it errors "not found"), so we don't use it.
proj() {
    local name
    name="$(basename "$PWD")"
    zellij --layout project attach "$name" -c
}

# Open the current repo as a project TAB in the current zellij session
# (project layout: nvim + Claude Code + scratch), named after the dir.
#   - Outside zellij: defer to `proj` (a project gets its own session).
#   - Inside zellij:  focus the tab if it already exists, else create it.
# Run after cd-ing into the repo.
# Note: running projtab again for the same repo has occasionally produced a
# duplicate tab instead of focusing the existing one; cause not pinned down
# (not worth chasing — a stray tab is cheap to close).
projtab() {
    local name
    name="$(basename "$PWD")"
    if [ -z "$ZELLIJ" ]; then
        proj
    elif zellij action query-tab-names 2>/dev/null | grep -qx "$name"; then
        zellij action go-to-tab-name "$name"
    else
        zellij action new-tab --layout project --cwd "$PWD" --name "$name"
    fi
}

# Zoxide (smarter cd)
alias cd='z'

# Python virtual environment
alias act='source .venv/bin/activate'

# Quick edits
alias aliases='nvim ~/.aliases'
alias reload='source ~/.bashrc'
